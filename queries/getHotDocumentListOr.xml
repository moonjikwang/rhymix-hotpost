<query id="getHotDocumentListOr" action="select">
	<tables>
		<table name="documents" />
	</tables>
	<columns>
		<column name="*" />
	</columns>
	<conditions>
		<condition operation="in" column="module_srl" var="module_srl" filter="number" />
		<condition operation="in" column="category_srl" var="category_srl" pipe="and" />
		<condition operation="in" column="status" var="statusList" pipe="and" />
		<condition operation="equal" column="is_notice" var="is_notice" pipe="and" />
		<condition operation="more" column="regdate" var="start_regdate" pipe="and" />
		<group pipe="and">
			<condition operation="more" column="readed_count" var="min_readed_count" filter="number" />
			<condition operation="more" column="voted_count" var="min_voted_count" filter="number" pipe="or" />
			<condition operation="more" column="comment_count" var="min_comment_count" filter="number" pipe="or" />
		</group>
	</conditions>
	<navigation>
		<index var="sort_index" default="list_order" order="order_type" />
		<list_count var="list_count" default="20" />
		<page_count var="page_count" default="10" />
		<page var="page" default="1" />
		<offset var="offset" />
	</navigation>
</query>
